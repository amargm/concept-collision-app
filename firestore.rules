rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── users/{uid} ──────────────────────────────────────────────────────────
    // Authenticated user reads and writes their own document only.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── collisions/{uid}/items/{id} ──────────────────────────────────────────
    // User may read their own collision items.
    // NO client writes — all writes come from the Cloud Run backend
    // using a service account (admin SDK bypasses these rules).
    match /collisions/{uid}/items/{id} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── collections/{uid}/items/{id} ─────────────────────────────────────────
    // Authenticated user has full CRUD on their own collection items.
    // Writes are validated: name must be a non-empty string, cardCount an int.
    match /collections/{uid}/items/{id} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasAll(['name', 'createdAt', 'cardCount'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.cardCount is int;

      allow update: if request.auth != null
        && request.auth.uid == uid
        // Prevent uid spoofing — disallow changing the owning uid if stored
        && (!request.resource.data.keys().hasAny(['uid'])
            || request.resource.data.uid == uid);
    }

    // ── daily/{date} ─────────────────────────────────────────────────────────
    // Any authenticated user may read the daily challenge.
    // No client writes — generated by Cloud Scheduler → Cloud Run backend.
    match /daily/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
